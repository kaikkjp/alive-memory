ANTHROPIC_API_KEY=sk-ant-...

# Required for heartbeat_server.py and terminal.py --connect
SHOPKEEPER_SERVER_TOKEN=replace-with-a-long-random-token

# Server bind settings
SHOPKEEPER_HOST=0.0.0.0
SHOPKEEPER_PORT=9999

# Database path (default: data/shopkeeper.db)
# SHOPKEEPER_DB_PATH=data/shopkeeper.db

# Client TLS (set on the machine running terminal.py --connect)
# SHOPKEEPER_TLS=true

# Phase 2: Cold memory search (semantic search over past conversations)
COLD_SEARCH_ENABLED=false
EMBED_PROVIDER=openai
OPENAI_API_KEY=sk-...

# fal.ai API key for image generation
# Get your key from: https://fal.ai/dashboard/keys
FAL_KEY=

# fal.ai model ID — must match the contract in pipeline/image_gen.py
# Swap only to models with the same input/output schema (see docstring)
FAL_IMAGE_MODEL=fal-ai/nano-banana-pro

# fal.ai image resolution: 1K | 2K | 4K
FAL_IMAGE_RESOLUTION=1K

# Window UI server ports
SHOPKEEPER_WS_PORT=8765
SHOPKEEPER_HTTP_PORT=8080
