# TASK-095 Phase 4: Multi-agent container image.
#
# Each agent runs as an isolated heartbeat_server.py process with its own
# DB, memory, identity, and config directory mounted at /agent-config.
#
# Build:   docker build -f deploy/Dockerfile.agent -t alive-engine:latest .
# Run:     docker run -d --name alive-agent-mybot \
#            -v /data/agents/mybot:/agent-config \
#            -e AGENT_ID=mybot \
#            -e AGENT_CONFIG_DIR=/agent-config \
#            -e OPENROUTER_API_KEY=sk-or-... \
#            -p 9001:8080 \
#            alive-engine:latest

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install Python deps first (layer cache)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source
COPY . .

# Non-root user
RUN adduser --disabled-password --no-create-home --gecos "" appuser \
    && mkdir -p /agent-config \
    && chown -R appuser:appuser /agent-config

# Only expose HTTP — no terminal, no WebSocket for managed agents
ENV SHOPKEEPER_HOST=0.0.0.0 \
    SHOPKEEPER_HTTP_PORT=8080

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/api/health')" || exit 1

USER appuser

CMD ["python", "heartbeat_server.py"]
